{
  "name": "voice-realtime-websocket",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "node server.js",
    "start": "electron .",
    "build": "electron-builder",
    "test:parity": "node --test --test-force-exit scripts/parity/dictation-flow.test.js",
    "test:cleanup": "node scripts/cleanup-test.js"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "dotenv": "^16.4.7",
    "koffi": "^3.0.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.purr.voicedictation",
    "productName": "Voice Dictation",
    "files": [
      "main.js",
      "preload.cjs",
      "server.js",
      "realtime-relay.js",
      "src/**/*",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
