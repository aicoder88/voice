{
  "name": "gvoice",
  "version": "1.0.0",
  "private": true,
  "description": "GVoice — hold-to-talk voice dictation that types out what you say.",
  "author": "Drago",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "node server.js",
    "start": "electron .",
    "build": "node scripts/copy-native.cjs && electron-builder",
    "test:parity": "node --test --test-force-exit scripts/parity/dictation-flow.test.js",
    "test:cleanup": "node scripts/cleanup-test.js",
    "test:unit": "node --test scripts/unit/*.test.js"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "dotenv": "^16.4.7",
    "koffi": "^3.0.2",
    "uiohook-napi": "^1.5.5",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.purr.gvoice",
    "productName": "GVoice",
    "npmRebuild": false,
    "files": [
      "main.js",
      "preload.cjs",
      "preload-pill.cjs",
      "preload-vocab.cjs",
      "preload-dictionary.cjs",
      "preload-splash.cjs",
      "preload-settings.cjs",
      "server.js",
      "realtime-relay.js",
      "src/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/native",
        "to": "koffi"
      }
    ],
    "icon": "build/icon.png",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "target": "dir",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "extendInfo": {
        "LSUIElement": true,
        "NSMicrophoneUsageDescription": "GVoice records while you hold the dictation key, then types out what you said."
      }
    },
    "win": {
      "icon": "build/icon.png",
      "target": "nsis"
    }
  }
}
