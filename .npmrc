# Flat, npm-style node_modules layout. electron-builder's dependency collector
# does not reliably follow pnpm's default nested/symlinked store, so a hoisted
# layout keeps the packaged app's bundled dependencies predictable. (The Windows
# paste path no longer depends on the jimp image stack — see src/typing.js — so
# this is robustness, not a hard requirement.)
node-linker=hoisted
