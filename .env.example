STT_PROVIDER=deepgram

DEEPGRAM_API_KEY=your-deepgram-api-key-here
DEEPGRAM_MODEL=nova-3
WHISPER_LANGUAGE=hr

OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime-2

# Local relay port. Leave unset to auto-pick a free port (recommended) so the
# relay never collides with another dev server on a well-known port like 3000 —
# a collision makes the dictation window load the wrong app. Pin only if needed.
# PORT=3000

CLEANUP_ENABLED=true
TYPE_VIA_CLIPBOARD=true

# Saved recordings (privacy). Everything you dictate is kept here as audio so a
# missed paste stays recoverable. Set RECORDINGS_ENABLED=false to keep none.
# RECORDING_RETENTION_DAYS bounds how long clips linger (on top of the last-50
# count cap); 0 = keep until the count cap evicts them. Both are also editable in
# the Settings window (tray → Settings…).
RECORDINGS_ENABLED=true
RECORDING_RETENTION_DAYS=7

# Custom dictionary: how long (ms) after a dictation to watch for a hand-typed
# correction (macOS/Linux). Set to 0 to disable manual-edit suggestions.
GVOICE_CORRECTION_WATCH_MS=12000

# Set to 1 to echo per-event traces to the console (always written to debug.log).
# GVOICE_DEBUG=1
